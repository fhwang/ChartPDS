# Root directory for all ChartPDS data (SQLite DB, content-addressed archive,
# derived store). Created automatically if it doesn't exist.
CHARTPDS_DATA_DIR=/path/to/chartpds-data

# Anthropic API — required only for narrative-PDF ingest (record_ingest with
# kind="clinical-pdf"), which runs a one-time LLM extraction. No other tool
# needs it.
# ANTHROPIC_API_KEY=sk-ant-...

# Optional Anthropic endpoint override (proxies/gateways; same variable the
# official Anthropic SDKs honor).
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Google Health / Fitbit adapter (optional — heart-rate sync). Create OAuth
# "Desktop app" credentials at https://console.cloud.google.com/apis/credentials
# GOOGLE_HEALTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_HEALTH_CLIENT_SECRET=your-client-secret

# Oura adapter (optional — sleep sync). Generate a personal access token at
# https://cloud.ouraring.com/personal-access-tokens
# OURA_PERSONAL_ACCESS_TOKEN=your-pat

# Sync daemon interval in seconds (default 300 = 5 minutes).
# Set to 0 to disable automatic syncing (manual source_sync tool calls only).
# CHARTPDS_SYNC_INTERVAL_SECS=300
